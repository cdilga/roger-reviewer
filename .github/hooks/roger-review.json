{
  "version": 1,
  "hooks": {
    "sessionStart": [
      {
        "type": "command",
        "bash": "./scripts/copilot-hooks/session-start.sh",
        "powershell": "./scripts/copilot-hooks/session-start.ps1",
        "cwd": ".",
        "timeoutSec": 15
      }
    ],
    "userPromptSubmitted": [
      {
        "type": "command",
        "bash": "./scripts/copilot-hooks/user-prompt.sh",
        "powershell": "./scripts/copilot-hooks/user-prompt.ps1",
        "cwd": ".",
        "timeoutSec": 10
      }
    ],
    "preToolUse": [
      {
        "type": "command",
        "bash": "./scripts/copilot-hooks/pre-tool-use.sh",
        "powershell": "./scripts/copilot-hooks/pre-tool-use.ps1",
        "cwd": ".",
        "timeoutSec": 10
      }
    ],
    "postToolUse": [
      {
        "type": "command",
        "bash": "./scripts/copilot-hooks/post-tool-use.sh",
        "powershell": "./scripts/copilot-hooks/post-tool-use.ps1",
        "cwd": ".",
        "timeoutSec": 10
      }
    ],
    "agentStop": [
      {
        "type": "command",
        "bash": "./scripts/copilot-hooks/agent-stop.sh",
        "powershell": "./scripts/copilot-hooks/agent-stop.ps1",
        "cwd": ".",
        "timeoutSec": 10
      }
    ],
    "sessionEnd": [
      {
        "type": "command",
        "bash": "./scripts/copilot-hooks/session-end.sh",
        "powershell": "./scripts/copilot-hooks/session-end.ps1",
        "cwd": ".",
        "timeoutSec": 10
      }
    ]
  }
}
